# Stripeテスト環境のキー（Stripeダッシュボード > Developers > API keys）
STRIPE_SECRET_KEY=sk_test_...

# StripeダッシュボードのWebhookセクションで取得
STRIPE_WEBHOOK_SECRET=whsec_...

# フロントエンドのURL（本番では変更）
BASE_URL=http://localhost:3000

# PostgreSQL（ローカルdocker-composeなら以下）
DATABASE_URL=postgresql+asyncpg://adctor:adctor@localhost:5432/adctor

# 計測キュー。ローカル検証は local、本番GCPは cloud-tasks。
TASK_QUEUE_BACKEND=local
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=asia-northeast1
CLOUD_RUN_WORKER_URL=https://your-worker-url.run.app
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker@your-gcp-project.iam.gserviceaccount.com
CLOUD_TASKS_QUEUE_PERPLEXITY=adctor-perplexity-crawl
CLOUD_TASKS_QUEUE_GEMINI=adctor-gemini-crawl
CLOUD_TASKS_QUEUE_OPENAI=adctor-openai-crawl

# Perplexity Sonar API（APIキーはコードに直書きしない）
PERPLEXITY_API_KEY=pplx_...
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_TIMEOUT_SECONDS=30

# Cloudflare AI Crawl Control GraphQL（実ログ同期用）
CLOUDFLARE_API_TOKEN=cf_api_token_with_analytics_read
CLOUDFLARE_GRAPHQL_ENDPOINT=https://api.cloudflare.com/client/v4/graphql
CLOUDFLARE_TIMEOUT_SECONDS=30
